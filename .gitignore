project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Rider
.idea/

# User-specific files
*.rsuser

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# macOS
.DS_Store

# Context file for tracking (not committed)
context.txt
planning.md
